# Veritabanı Konfigürasyonu
DATABASE_URL=postgres://app:CHANGEME@localhost:5432/owasp_lab
POSTGRES_USER=app
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=owasp_lab

# Uygulama Konfigürasyonu
APP_MODE=secure          # vulnerable | secure
BIND_ADDR=0.0.0.0:8080
SESSION_SECRET=CHANGE_ME_64_RANDOM_BYTES_HERE_FOR_SECURITY_REASONS
RUST_LOG=info
LOG_FORMAT=pretty          # json | pretty (pretty = readable development mode, json = SIEM production mode)

# Secrets Provider Konfigürasyonu
# Desteklenen değerler: env | vault | aws | doppler
# Varsayılan: env (ortam değişkenleri / .env dosyası)
SECRETS_PROVIDER=env
# VAULT_ADDR=http://127.0.0.1:8200
# VAULT_TOKEN=hvs.xxxxx
# VAULT_MOUNT=secret
# VAULT_PATH=owasp-lab/production
# DOPPLER_TOKEN=dp.st.xxxxx
# DOPPLER_PROJECT=owasp-lab
# DOPPLER_CONFIG=production
# AWS: Standart AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION env vars kullanılır
# AWS_SECRET_NAME=owasp-lab/production
